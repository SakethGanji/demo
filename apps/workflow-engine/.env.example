# Database (Postgres)
WORKFLOW_DB_HOST=localhost
WORKFLOW_DB_PORT=5432
WORKFLOW_DB_USER=workflow
WORKFLOW_DB_PASSWORD=workflow
WORKFLOW_DB_NAME=workflows
# NGC secret (prod — overrides DB_PASSWORD)
# WORKFLOW_DB_PASSWORD_SECRET_NAME=my-pg-password
# WORKFLOW_NGC_CSIID=179492

# Credential encryption key (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
WORKFLOW_ENCRYPTION_KEY=

# Server
WORKFLOW_HOST=0.0.0.0
WORKFLOW_PORT=8000
WORKFLOW_DEBUG=false
WORKFLOW_RELOAD=true
WORKFLOW_LOG_LEVEL=info

# Production
WORKFLOW_RETENTION_DAYS=30
WORKFLOW_STALE_EXECUTION_HOURS=4

# AI keys
WORKFLOW_OPENAI_API_KEY=
WORKFLOW_ANTHROPIC_API_KEY=
WORKFLOW_GEMINI_API_KEY=
